# Letta Backgammon config
# Copy to .env and fill in your values, or delete .env and run `node server.js` for interactive setup

# Game names (shown in the UI)
PLAYER_NAME=YourName
AGENT_NAME=YourAgentName

# Letta API credentials
LETTA_API_KEY=sk-your-api-key
LETTA_AGENT_ID=agent-your-agent-id

# Letta base URL (leave blank or omit for Letta Cloud; set for self-hosted)
# LETTA_BASE_URL=http://localhost:8283

# Discord integration (optional -- for posting agent responses to a channel)
# Bot token: same one in your lettabot.yaml under channels.discord.token
# Channel ID: right-click channel in Discord (Developer Mode) -> Copy Channel ID
# Sender name: your Discord username (so the agent responds to a recognized sender)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id
DISCORD_SENDER_NAME=your-discord-username

# Override channel name if auto-fetch fails (optional)
# DISCORD_CHANNEL_NAME=game-room

# Server port
PORT=3000
