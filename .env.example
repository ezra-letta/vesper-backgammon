# Letta API credentials (for agent AI responses)
LETTA_API_KEY=your-letta-api-key-here
LETTA_AGENT_ID=your-agent-id-here

# Discord credentials (for posting agent responses to your channel)
# Bot token: same one in your lettabot.yaml under channels.discord.token
# Channel ID: right-click channel in Discord (Developer Mode) -> Copy Channel ID
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-channel-id-here

# Server port (default: 3000)
PORT=3000
